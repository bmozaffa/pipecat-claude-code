# ElevenLabs — required for STT and TTS
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Voice ID to use for TTS (default: Rachel)
# Browse voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# OpenAI-compatible LLM endpoint
# Leave OPENAI_BASE_URL unset to use OpenAI directly.
# For local inference examples:
#   Ollama:   OPENAI_BASE_URL=http://localhost:11434/v1
#   LM Studio: OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
